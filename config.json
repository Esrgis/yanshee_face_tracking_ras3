      "B": {"base_skip": 5, "alpha": 0.0,  "beta": 0.0},
      "C": {"base_skip": 5, "alpha": 0.08, "beta": 0.0},
      "D": {"base_skip": 5, "alpha": 0.08, "beta": 0.2}
    },
    "min_skip": 1,
    "max_skip": 15,
    "velocity_window": 5
  },
  "robot_yanshee": {
    "servo_min_abs": 15,
    "servo_max_abs": 165,
    "servo_center": 90,
    "timeout_lost": 3.0,
