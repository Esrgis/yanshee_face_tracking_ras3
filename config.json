{
  "system": {
    "use_kalman": true,
    "display_ui": false,
    "log_csv": true
  },
  "hardware": {
    "robot_ip": "192.168.31.239",
    "use_multithreading": true,
    "servo_direction": -1,
    "min_command_interval_sec": 0.08,
