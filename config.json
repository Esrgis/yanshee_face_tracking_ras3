{
  "system": {
    "use_kalman": true,
    "display_ui": true,
    "log_csv": true
  },
  "camera": {
    "cascade_path": "haarcascade_frontalface_default.xml",
    "frame_width": 640,
    "frame_height": 480,
    "detection_skip_frames": 3
  },
  "adaptive_scheduler": {
    "enabled": true,
    "base_skip": 5,
    "min_skip": 1,
    "max_skip": 15,
    "alpha": 0.08,
    "beta": 0.05,
    "velocity_window": 5
  },
  "robot_yanshee": {
    "max_angle": 45,
    "min_angle": -45,
    "timeout_lost": 3.0,
    "lost_frame_threshold": 5,
    "default_angle": 0,
    "backoff_delta": 5
  },
  "controller_pid": {
    "Kp": 0.05,
    "Ki": 0.0,
    "Kd": 0.01,
    "max_integral": 50.0,
    "deadzone": 2.0,
    "output_limit": 15.0
  },
  "filter_kalman": {
    "process_noise_cov": 0.03,
    "measurement_noise_cov": 0.1
  },
  "testing_env": {
    "webcam_index": 0
  }
}